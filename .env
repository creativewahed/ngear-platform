# Application Configuration
NODE_ENV=development
PORT=3000
APP_NAME=NGEAR Platform
APP_VERSION=1.0.0
GLOBAL_PREFIX=api/v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ngear
DB_PASSWORD=password
DB_NAME=ngear_platform
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_MIGRATIONS_RUN=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=ngear:

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ngear-platform
JWT_AUDIENCE=ngear-clients

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Microservices Configuration
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=3001
TENANT_SERVICE_HOST=localhost
TENANT_SERVICE_PORT=3002
USER_SERVICE_HOST=localhost
USER_SERVICE_PORT=3003
WALLET_SERVICE_HOST=localhost
WALLET_SERVICE_PORT=3004
NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_PORT=3005
ANALYTICS_SERVICE_HOST=localhost
ANALYTICS_SERVICE_PORT=3006

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ngear-api-gateway
KAFKA_GROUP_ID=ngear-gateway-group

# Email Configuration
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@ngear-platform.com

# File Upload Configuration
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
UPLOAD_PATH=uploads
UPLOAD_TEMP_PATH=temp

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true