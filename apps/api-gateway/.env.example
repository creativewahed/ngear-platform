# Environment variables for API Gateway
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/ngear_platform?schema=public"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRY="24h"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Logging
LOG_LEVEL=debug