# NGEAR Platform Environment Variables

# Node.js Environment
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/ngear_platform?schema=public"
REDIS_URL="redis://localhost:6379"
MONGODB_URL="mongodb://admin:password@localhost:27017/ngear_platform?authSource=admin"
ELASTICSEARCH_URL="http://localhost:9200"

# Authentication & Security
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="24h"
REFRESH_TOKEN_EXPIRY="7d"

# API Gateway Configuration
API_GATEWAY_PORT=3000
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug

# Email Configuration (for production)
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""

# File Storage (for production)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION=""

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=""
SENTRY_DSN=""

# Kafka Configuration
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="ngear-platform"

# External API Keys (for integrations)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""