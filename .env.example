# Global Environment Configuration
NODE_ENV=development

# Service Ports
AUTH_SERVICE_PORT=3001
TENANT_SERVICE_PORT=3002
USER_SERVICE_PORT=3003
API_GATEWAY_PORT=3100
PLATFORM_ADMIN_PORT=3000
CLIENT_PORTAL_PORT=3010

# Database Configuration
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password

# MongoDB
MONGODB_URI=mongodb://admin:password@localhost:27017/ngear_platform?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3010

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@ngear.com

# External Services
WEBHOOK_SECRET=your-webhook-secret

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_EMAIL_VERIFICATION=true