# Environment
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://ngear_user:ngear_password@localhost:5432/ngear_platform
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ngear_platform
DATABASE_USERNAME=ngear_user
DATABASE_PASSWORD=ngear_password

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017/ngear_platform

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-here-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OAuth Configuration (Optional)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Email Configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=noreply@ngear.com
SMTP_PASSWORD=email_password

# AWS Configuration (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ngear-platform

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info

# Security
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your-32-character-encryption-key-here

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# External Services (Optional)
PAYMENT_GATEWAY_URL=
PAYMENT_GATEWAY_API_KEY=
NOTIFICATION_SERVICE_URL=