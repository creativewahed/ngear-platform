{
  "version": "1.0.0",
  "npmClient": "npm",
  "command": {
    "publish": {
      "conventionalCommits": true,
      "message": "chore(release): publish"
    },
    "version": {
      "allowBranch": [
        "main",
        "develop"
      ],
      "conventionalCommits": true
    }
  },
  "packages": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "useWorkspaces": true,
  "stream": true
}