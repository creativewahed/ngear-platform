{
  "name": "@ngear/wallet",
  "version": "1.0.0",
  "description": "Intelligent wallet management service for NGEAR platform",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
